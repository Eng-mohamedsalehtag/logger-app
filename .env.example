# Frontend (Vite — set in Vercel → Environment Variables)
VITE_USE_MOCK=false
VITE_API_URL=/api

# Backend (set in Vercel → Environment Variables)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/observify
JWT_SECRET=your-long-random-secret
JWT_EXPIRES_IN=7d
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# Local backend only
PORT=5000
